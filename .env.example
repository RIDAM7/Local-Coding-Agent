# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434

# Models
PLANNER_MODEL=qwen2.5:14b # Assuming qwen2.5:14b or similar is used, replace with actual name if different, e.g. qwen:14b
CODER_MODEL=qwen2.5-coder:32b # Using qwen coder equivalent, replace if needed

# Workspace settings
WORKSPACE_DIR=./workspace # Default workspace directory for operations

# Logging
LOG_LEVEL=INFO

# Validation
BUILD_COMMAND=
LINT_COMMAND=
TEST_COMMAND=

# Repair
MAX_REPAIR_ATTEMPTS=3
