# =============================================================================
# Local Coding Agent — configuration reference
# Everything has a working default. With NOTHING set, the agent runs fully local
# on Ollama (zero config). A cloud API key is only required if you actually point
# a role at that provider.
# =============================================================================

# --- Ollama (local) ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# --- Models (per role) -------------------------------------------------------
# Base roles. Legacy names still honored.
PLANNER_MODEL=qwen2.5:14b
CODER_MODEL=qwen2.5-coder:32b
# Optional per-role model overrides. Empty = inherit:
#   constraint <- planner ;  repair/reflection <- coder ;  refiner/reviewer <- planner
REFINER_MODEL=
REPAIR_MODEL=
CONSTRAINT_MODEL=
REFLECTION_MODEL=
REVIEWER_MODEL=

# --- Providers (per role) ----------------------------------------------------
# One of: ollama | openai | anthropic | google
# Base roles default to "ollama". Derived roles default to "" (inherit) using the
# same rules as models above. Mix freely, e.g. local planner + cloud coder.
PLANNER_PROVIDER=ollama
CODER_PROVIDER=ollama
REFINER_PROVIDER=
REPAIR_PROVIDER=
CONSTRAINT_PROVIDER=
REFLECTION_PROVIDER=
REVIEWER_PROVIDER=

# --- Cloud credentials (only needed if a role uses that provider) ------------
# OpenAI and ANY OpenAI-compatible gateway share these two vars — just change
# the base_url + key + model:
#   OpenRouter : https://openrouter.ai/api/v1
#   Groq       : https://api.groq.com/openai/v1
#   Together   : https://api.together.xyz/v1
#   DeepSeek   : https://api.deepseek.com/v1
#   Fireworks  : https://api.fireworks.ai/inference/v1
#   vLLM/LMStudio (local): http://localhost:8000/v1  (key can be any non-empty string)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (also used by the Claude reviewer)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# Google Gemini
GOOGLE_API_KEY=

# --- Prompt refiner (Phase 3, optional) --------------------------------------
# When true, a pre-planning stage rewrites the raw task into a clearer, better-
# structured instruction (preserving intent/scope) before constraint extraction
# and planning. Off by default -> pipeline is byte-for-byte the old path. On any
# refiner failure the run falls back to the raw prompt. The refiner uses the
# "refiner" role: REFINER_PROVIDER / REFINER_MODEL above (both inherit planner
# when blank).
REFINER_ENABLED=false

# --- Workspace ---------------------------------------------------------------
WORKSPACE_DIR=./workspace

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Validation commands (optional) ------------------------------------------
# Run after a patch applies. Empty = that stage is skipped (reported as success).
BUILD_COMMAND=
LINT_COMMAND=
TEST_COMMAND=

# --- Command execution (Phase 4a) --------------------------------------------
# The coder may propose shell commands alongside file edits. When EXECUTE_COMMANDS
# is false (default) those commands are shown in the report as "proposed (NOT
# executed)" and never run — nothing executes silently. Set to true to actually
# run them via the Executor after a patch applies; a non-zero exit code is fed
# into the same self-healing repair loop as a failing build/test.
# NOTE: there is no command allowlist / diff-preview / sandbox yet (that is the
# upcoming safety phase), so only enable this against a trusted workspace.
EXECUTE_COMMANDS=false
# Max seconds any single command (validation or executed) may run before timeout.
COMMAND_TIMEOUT=60

# --- Repair ------------------------------------------------------------------
# Max self-healing repair attempts before rollback.
MAX_REPAIR_ATTEMPTS=3

# --- LLM retries -------------------------------------------------------------
# Structured-output retry/repair attempts per LLM call (all providers).
MAX_RETRIES=3
